async def cmd_00(update, ticker, data):
    personality = random.choice(PERSONALITIES)
    price = data['price']
    target = round(price * 1.09, 2)
    profit = round((target - price) / price * 100, 1)
    trend = "稳步上涨" if data['change_1d'] > 1 else "小幅收涨" if data['change_1d'] > 0 else "窄幅震荡" if data['change_1d'] > -1 else "短期回调"
    try:
        hist = yf.Ticker(ticker).history(period="1y")
        if not hist.empty:
            year_high = hist["High"].max()
            year_low = hist["Low"].min()
            pos_1y = (price - year_low) / (year_high - year_low) * 100
            trend_1y = "近一年低位区域" if pos_1y < 30 else "近一年高位区域" if pos_1y > 70 else "近一年中位区域"
            weak_stock = pos_1y < 30
        else:
            year_high, year_low, weak_stock = price * 1.2, price * 0.8, False
    except:
        year_high, year_low, weak_stock = price * 1.2, price * 0.8, False
    is_active = data['volume_ratio'] > 1.2
    time_horizon = "1个月内" if is_active else "3–6个月内" if weak_stock else "2–4个月内"
    advice = f"该股当前{trend}，处于{trend_1y}（{pos_1y:.0f}%），量比 {data['volume_ratio']:.1f}x。{'若亏损不大，可考虑持有观察，目标看 ${target}。' if not weak_stock else f'该股处于低位，预计 {time_horizon} 内存在修复机会。'}"
    plan = f"🎯 *00 交易计划* | {ticker} {data['name']}\n💰 价格: ${price}\n📈 目标: ${target}（+{profit}%）\n📊 趋势: {trend}\n⚡ 量比: {data['volume_ratio']:.1f}x\n📅 近1年位置: {trend_1y}（{pos_1y:.0f}%）\n\n📋 方案:\n• 入场: ${price * 0.97:.2f} ~ ${price * 1.02:.2f}\n• 止损: ${price * 0.94:.2f}（-6%）\n• 止盈: ${target}\n\n💡 *{personality} 的建议*\n{advice}\n\n⚠️ 仅供参考，不构成投资建议"
    await update.message.reply_text(plan, parse_mode="Markdown")
    chart = generate_kline_chart(ticker)
    if chart:
        await update.message.reply_photo(photo=chart, caption=f"📈 {ticker} 日线K线图 (MA5/MA20)")

